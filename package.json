{
  "name": "solstice",
  "version": "0.1.0",
  "description": "A calm, local-first daily planner. Notes and tasks organized by day, not by folder.",
  "author": "Amit Biswas",
  "license": "MIT",
  "homepage": "https://github.com/amit-biswas-1992/solstice",
  "repository": {
    "type": "git",
    "url": "https://github.com/amit-biswas-1992/solstice.git"
  },
  "bugs": {
    "url": "https://github.com/amit-biswas-1992/solstice/issues"
  },
  "keywords": [
    "daily-notes",
    "planner",
    "desktop",
    "electron",
    "local-first",
    "tasks",
    "productivity",
    "calendar",
    "note-taking",
    "day-planner"
  ],
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "clean:electron": "node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\"",
    "dev": "vite",
    "dev:electron": "npm run clean:electron && concurrently -k \"npm:dev\" \"npm:dev:electron:ts\" \"npm:dev:electron:app\"",
    "dev:electron:ts": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron:app": "wait-on http://localhost:5173 dist-electron/electron/main.js dist-electron/electron/preload.js && VITE_DEV_SERVER_URL=http://localhost:5173 nodemon --watch dist-electron --ext js --exec \"electron .\"",
    "build": "tsc && vite build && npm run clean:electron && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "smoke": "npm run build && playwright test",
    "package": "npm run build && electron-builder",
    "demo:capture": "node scripts/capture-demo-assets.mjs",
    "demo:video": "remotion render remotion/index.ts DailyNotesDesktopDemo artifacts/solstice-demo.mp4"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@remotion/cli": "^4.0.467",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "remotion": "^4.0.467",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.neutrix.dailynotes",
    "productName": "Daily Notes Desktop",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ]
  }
}
